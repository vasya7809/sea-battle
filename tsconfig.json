{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "rootDir": "./server/src",
    "outDir": "./dist/server",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node16",
    "types": ["node"],
    "typeRoots": ["./node_modules/@types"],
    "skipLibCheck": true
  },
  "include": ["server/src/**/*"]
}
